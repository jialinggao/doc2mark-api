# ==================== 服务配置 ====================
# 服务监听端口
SERVICE_PORT=5926
# 日志级别
LOG_LEVEL=INFO

# ==================== Redis 配置 ====================
# Redis 主机地址
REDIS_HOST=redis
# Redis 端口
REDIS_PORT=6379
# Redis 数据库编号
REDIS_DB=0

# ==================== LLM 配置（支持本地模型）====================
# 是否启用 LLM
ENABLE_LLM=true

# API 配置（本地模型请修改 LLM_BASE_URL）
# LLM API 地址
LLM_BASE_URL=
# LLM API Key（本地模型可填任意值）
LLM_API_KEY=
# LLM 模型名称
LLM_MODEL=

# 提示词配置
# LLM 用户提示词
LLM_PROMPT=请分析这张图片并按以下规则输出：\n\n【表格/文字内容】\n- 完整提取所有文字和表格内容\n- 表格使用Markdown格式（|分隔），保持行列结构\n- 保留原文的层级、编号、标题等格式\n\n【图表/示意图/照片】\n- 描述图表类型（柱状图、折线图、流程图等）\n- 提取关键数据点和趋势\n- 描述视觉元素的颜色、布局、标注\n- 描述控制在300字以内\n\n【混合内容】\n- 先输出表格/文字部分\n- 再输出图表描述部分\n- 用分隔线（---）区分\n\n【通用要求】\n- 所有输出必须为中文\n- 不要添加"好的"、"根据图片"等开场白\n- 直接输出结果
# LLM 系统提示词
LLM_SYSTEM_PROMPT=你是一个专业的图片分析和内容提取助手。请严格按照指令分析图片，保持输出准确、结构化。

# 推理参数（根据官网参数配置）
# 温度系数，0-1，越低越确定（固定提取任务使用低温度）
LLM_TEMPERATURE=0.1
# 核采样
LLM_TOP_P=0.9
# 候选 Token 数量，非 OpenAI 标准参数（不需要则留空）
# LLM_TOP_K=
# 重复度惩罚，非 OpenAI 标准参数（不需要则留空）
# LLM_REPETITION_PENALTY=
# 最大输出 Token（Qwen3.6-Flash 最大支持 64K，设置为 16K 平衡性能与可用性）
LLM_MAX_TOKENS=16384
# 请求超时时间（秒），冷启动时可能需要较长时间
LLM_TIMEOUT=300
# 是否启用流式应答，true: 边生成边输出
LLM_STREAM=false
# 是否在响应中包含 Token 用量信息
LLM_INCLUDE_USAGE=true
# 额外参数，用于控制深度思考等非标准功能（JSON 格式）
LLM_EXTRA_BODY={"enable_thinking": false, "thinking": {"type": "disabled"},"chat_template_kwargs": {"enable_thinking": false}}
# 额外顶层参数，用于传递非 extra_body 的其他扩展参数（JSON 格式）
LLM_EXTRA_PARAMS={}

# ==================== OCR 配置 ====================
# 是否启用 OCR
OCR_ENABLED=true
# OCR 语言（chi_sim=简体中文，eng=英文）
OCR_LANGUAGE=chi_sim+eng
# Tesseract 可执行路径（Windows 示例：C:\Program Files\Tesseract-OCR\tesseract.exe）
# OCR_TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Docker 容器内已预装，通常不需要设置
OCR_TESSERACT_PATH=
# OCR 最小识别长度
OCR_MIN_LENGTH=3
# OCR 最小置信度
OCR_MIN_CONFIDENCE=0.6
# OCR 最大符号比例
OCR_MAX_SYMBOL_RATIO=0.5

# ==================== 图片处理配置 ====================
# 图片质量 1-100，100 表示不压缩
DEFAULT_IMAGE_QUALITY=100
# 图片最长边限制（像素），-1 表示不限制
DEFAULT_MAX_IMAGE_SIZE=-1

# ==================== 服务限制 ====================
# 每分钟最大请求数
MAX_REQUESTS_PER_MINUTE=60
# 允许的跨域来源
ALLOWED_ORIGINS=*
# 最大文件大小（字节）
MAX_FILE_SIZE=52428800

# ==================== 任务配置 ====================
# 任务保留时间（秒）
TASK_TTL=86400
# 结果保留时间（秒）
RESULT_TTL=43200
# 清理间隔（分钟）
CLEANUP_INTERVAL_MINUTES=10

# ==================== Worker 配置 ====================
# 同步任务等待超时（秒）
SYNC_TASK_TIMEOUT=300
# 异步任务执行超时（秒），默认 6 小时
ASYNC_TASK_TIMEOUT=21600
# 同步 Worker 进程数
SYNC_WORKER_COUNT=2
# 异步 Worker 进程数
ASYNC_WORKER_COUNT=4
